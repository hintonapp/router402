# Server Configuration
# Port number for the server to listen on
# Default: 8080
PORT=8080

# Node environment (development, production, test)
# Default: development
NODE_ENV=development

# Chain environment (mainnet | testnet)
# Determines which blockchain network to use, independent of NODE_ENV
# Default: testnet
CHAIN_ENV=testnet

# CORS origin for cross-origin requests
# Must be a valid URL
# Default: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database URL
DATABASE_URL="postgresql://username:password@host.neon.tech/neondb"

# WalletConnect Project ID (Required)
WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Base RPC URL (Optional - defaults to WalletConnect RPC)
# RPC_URL=https://mainnet.base.org/

# x402 Payment Configuration
# Wallet address to receive payments
PAY_TO=0x5Ba55eaBD43743Ef6bB6285f393fA3CbA33FbA5e
PAY_TO_SOLANA=Hq3d3ErZgvA5aGn6gLWFa9KncoCS4GZ7nJyZEZXkfAQQ

# x402 Facilitator URL
# Default: https://x402.router402.xyz
FACILITATOR_URL=https://x402.router402.xyz

# JWT Secret for authorization tokens (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"

# Pimlico API Key for account abstraction
PIMLICO_API_KEY=""

ANTHROPIC_API_KEY=""

GOOGLE_API_KEY=""

PIMLICO_API_KEY=""

# Alibaba Cloud DashScope (for Qwen models)
DASHSCOPE_API_KEY=""
# Optional — override region base URL
# Singapore (default): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US Virginia:         https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Beijing:             https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=""

# Moonshot AI (for Kimi models)
MOONSHOT_API_KEY=""
# Optional — override base URL (default: https://api.moonshot.ai/v1)
# MOONSHOT_BASE_URL=""
